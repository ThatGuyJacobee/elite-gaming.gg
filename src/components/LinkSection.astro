---
interface Props {
    title: string;
    description?: string;
    columns?: 1 | 2;
}

const { title, description, columns = 2 } = Astro.props;
const gridClass = columns === 1 ? "grid-cols-1" : "grid-cols-1 sm:grid-cols-2";
---

<section class="space-y-4">
    <div class="space-y-1">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-secondary">
            {title}
        </h2>
        {description ? <p class="text-sm text-zinc-600 dark:text-zinc-300">{description}</p> : null}
    </div>

    <div class:list={["grid gap-4", gridClass]}>
        <slot />
    </div>
</section>
