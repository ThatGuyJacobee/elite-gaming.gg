<div
    class="inline-flex items-center gap-1 rounded-full border border-zinc-200 bg-white/80 p-1 shadow-sm backdrop-blur-sm dark:border-zinc-800 dark:bg-white/5"
    data-theme-toggle
    role="group"
    aria-label="Theme preference"
>
    <button
        type="button"
        class="rounded-full px-3 py-1.5 text-sm font-medium text-zinc-600 transition hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-brand-secondary/40 data-[active=true]:bg-zinc-900 data-[active=true]:text-zinc-50 data-[active=true]:shadow-sm dark:text-zinc-300 dark:hover:text-zinc-100 dark:data-[active=true]:bg-zinc-100 dark:data-[active=true]:text-zinc-950"
        data-theme-option="system"
        data-active="false"
        aria-pressed="false"
    >
        System
    </button>
    <button
        type="button"
        class="rounded-full px-3 py-1.5 text-sm font-medium text-zinc-600 transition hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-brand-secondary/40 data-[active=true]:bg-zinc-900 data-[active=true]:text-zinc-50 data-[active=true]:shadow-sm dark:text-zinc-300 dark:hover:text-zinc-100 dark:data-[active=true]:bg-zinc-100 dark:data-[active=true]:text-zinc-950"
        data-theme-option="light"
        data-active="false"
        aria-pressed="false"
    >
        Light
    </button>
    <button
        type="button"
        class="rounded-full px-3 py-1.5 text-sm font-medium text-zinc-600 transition hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-brand-secondary/40 data-[active=true]:bg-zinc-900 data-[active=true]:text-zinc-50 data-[active=true]:shadow-sm dark:text-zinc-300 dark:hover:text-zinc-100 dark:data-[active=true]:bg-zinc-100 dark:data-[active=true]:text-zinc-950"
        data-theme-option="dark"
        data-active="false"
        aria-pressed="false"
    >
        Dark
    </button>
</div>

<script is:inline>
    const toggle = document.querySelector("[data-theme-toggle]");

    if (toggle) {
        const buttons = Array.from(toggle.querySelectorAll("[data-theme-option]"));

        const syncButtons = () => {
            const activePreference = document.documentElement.dataset.themePreference ?? "system";

            buttons.forEach((button) => {
                const isActive = button.dataset.themeOption === activePreference;

                button.setAttribute("aria-pressed", String(isActive));
                button.dataset.active = String(isActive);
            });
        };

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                window.__setThemePreference?.(button.dataset.themeOption ?? "system");
            });
        });

        syncButtons();
        document.addEventListener("themechange", syncButtons);
    }
</script>
