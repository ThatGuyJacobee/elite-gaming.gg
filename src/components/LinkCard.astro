---
import { Icon } from "astro-icon/components";

interface Props {
    href: string;
    title: string;
    description: string;
    icon: string;
    featured?: boolean;
}

const { href, title, description, icon, featured = false } = Astro.props;
const cardClass = featured ? "px-6 py-5 sm:py-6" : "px-5 py-4";
const iconBoxClass = featured ? "size-14" : "size-12";
const iconClass = featured ? "size-7" : "size-6";
const titleClass = featured ? "text-xl" : "text-lg";
---

<a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
        "group flex items-center gap-4 rounded-2xl border border-zinc-200 bg-white/80 text-left transition hover:border-brand-primary hover:bg-white dark:border-zinc-800 dark:bg-white/5 dark:hover:bg-white/10",
        cardClass,
    ]}
>
    <span
        class:list={[
            "flex shrink-0 items-center justify-center rounded-xl bg-brand-secondary/15 text-brand-secondary transition group-hover:bg-brand-primary/15 group-hover:text-brand-primary",
            iconBoxClass,
        ]}
    >
        <Icon name={icon} class={iconClass} aria-hidden="true" />
    </span>

    <span class="min-w-0">
        <span class:list={["block font-semibold", titleClass]}>{title}</span>
        <span class="mt-1 block text-sm text-zinc-600 dark:text-zinc-300">{description}</span>
    </span>
</a>
